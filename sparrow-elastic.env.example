# sparrow-elastic.env — Shell-format environment variables for the
# Sparrow WiFi/BT Elasticsearch bridge.
#
# Copy to /etc/sparrow-elastic.env and customize.
# This file is sourced by the systemd unit via EnvironmentFile=.
# Syntax: KEY=value, one per line. No shell quoting required for simple values.
# Lines beginning with # are comments.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Full URL of the Elasticsearch or OpenSearch cluster.
# Include credentials in the URL or set USERNAME/PASSWORD separately.
SPARROW_ES_URL=http://elastic:changeme@localhost:9200

# ---------------------------------------------------------------------------
# Engine
# ---------------------------------------------------------------------------

# "elasticsearch" (default) or "opensearch"
# SPARROW_ES_ENGINE=elasticsearch

# ---------------------------------------------------------------------------
# Auth (alternative to embedding credentials in SPARROW_ES_URL)
# ---------------------------------------------------------------------------

# SPARROW_ES_USERNAME=elastic
# SPARROW_ES_PASSWORD=changeme

# Elasticsearch API key (not supported on OpenSearch)
# SPARROW_ES_API_KEY=

# ---------------------------------------------------------------------------
# Fingerbank (optional)
# ---------------------------------------------------------------------------

# SPARROW_FINGERBANK_API_KEY=
