{
  "template": {
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "@timestamp": { "type": "date" },
        "ecs": {
          "properties": {
            "version": { "type": "keyword" }
          }
        },
        "event": {
          "properties": {
            "dataset":   { "type": "keyword" },
            "kind":      { "type": "keyword" },
            "category":  { "type": "keyword" },
            "type":      { "type": "keyword" },
            "action":    { "type": "keyword" },
            "module":    { "type": "keyword" },
            "ingested":  { "type": "date" }
          }
        },
        "observer": {
          "properties": {
            "id":       { "type": "keyword" },
            "hostname": { "type": "keyword" },
            "type":     { "type": "keyword" },
            "vendor":   { "type": "keyword" },
            "product":  { "type": "keyword" },
            "geo": {
              "properties": {
                "location": { "type": "geo_point" },
                "altitude": { "type": "float" }
              }
            },
            "gps": {
              "properties": {
                "status": { "type": "keyword" }
              }
            }
          }
        },
        "source": {
          "properties": {
            "mac":     { "type": "keyword" },
            "address": { "type": "keyword" }
          }
        },
        "device": {
          "properties": {
            "id":               { "type": "keyword" },
            "class_guess":      { "type": "keyword" },
            "class_confidence": { "type": "float" },
            "class_evidence":   { "type": "keyword" }
          }
        },
        "related": {
          "properties": {
            "hash":  { "type": "keyword" },
            "mac":   { "type": "keyword" },
            "hosts": { "type": "keyword" }
          }
        },
        "rf": {
          "properties": {
            "frequency_mhz":    { "type": "long" },
            "band":             { "type": "keyword" },
            "channel_occupied_set": { "type": "integer" },
            "signature": {
              "properties": {
                "controller_candidate": { "type": "boolean" }
              }
            }
          }
        },
        "signal": {
          "properties": {
            "strength_dbm":         { "type": "float" },
            "strength_mw":          { "type": "float" },
            "strength_quality_0_5": { "type": "byte" }
          }
        },
        "observed": {
          "properties": {
            "first_seen":       { "type": "date" },
            "last_seen":        { "type": "date" },
            "age_seconds":      { "type": "long" },
            "hour_utc":         { "type": "byte" },
            "day_of_week_utc":  { "type": "keyword" },
            "hour_local":       { "type": "byte" },
            "day_of_week_local": { "type": "keyword" },
            "timezone_local":   { "type": "keyword" }
          }
        },
        "threat": {
          "properties": {
            "indicator": {
              "properties": {
                "type":  { "type": "keyword" },
                "value": { "type": "keyword" }
              }
            }
          }
        },
        "host": {
          "properties": {
            "hostname": { "type": "keyword" }
          }
        },
        "bluetooth": {
          "properties": {
            "name":         { "type": "keyword", "ignore_above": 256 },
            "company":      { "type": "keyword" },
            "manufacturer": { "type": "keyword" },
            "description":  { "type": "keyword" },
            "type":         { "type": "keyword" },
            "mac": {
              "properties": {
                "randomized": { "type": "boolean" },
                "type":       { "type": "keyword" }
              }
            },
            "advertising": {
              "properties": {
                "type":         { "type": "keyword" },
                "flags":        { "type": "integer" },
                "appearance":   { "type": "integer" },
                "tx_power_dbm": { "type": "float" }
              }
            },
            "beacon": {
              "properties": {
                "type":          { "type": "keyword" },
                "uuid":          { "type": "keyword" },
                "major":         { "type": "integer" },
                "minor":         { "type": "integer" },
                "eddystone_url": { "type": "keyword" }
              }
            },
            "apple": {
              "properties": {
                "continuity_type": { "type": "keyword" }
              }
            },
            "ibeacon_range_m": { "type": "float" },
            "uuid":           { "type": "keyword" },
            "geo": {
              "properties": {
                "location": { "type": "geo_point" }
              }
            }
          }
        }
      }
    }
  }
}
